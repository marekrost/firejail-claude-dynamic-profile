#!/bin/bash

# claude-sandbox - Run Claude in a sandboxed firejail environment
# This script runs Claude in firejail with filesystem isolation
# while maintaining access to current directory and Claude configuration
# Unlike static .profile file - this script adaptively selects active node.js environment
# which is helpful to systems running mise and would be impossible with a static .profile file.

set -euo pipefail

# =============================================================================
# Integrate into current developer environment
# =============================================================================
real_path() {
    readlink -f "$(which "$1")"
}

CURRENT_DIR="$(pwd)"
BREW_ROOT="/home/linuxbrew"

MISE_BIN="$(real_path mise)"
MISE_DATA="$HOME/.local/share/mise"

NODE_BIN="$(mise which node)"
NODE_INSTALL_ROOT="$(mise where node)"

UV_BIN="$(real_path uv)"
UVX_BIN="$(real_path uvx)"
UV_DATA="$HOME/.local/share/uv"
UV_CACHE="$HOME/.cache/uv"

CLAUDE_BIN="$(mise which claude)"
CLAUDE_SETUP="exec \"$NODE_BIN\" \"$CLAUDE_BIN\" --dangerously-skip-permissions \"\$@\""
SHELL_SETUP="eval \"\$($BREW_ROOT/.linuxbrew/bin/brew shellenv)\"; eval \"\$($MISE_BIN activate bash)\"; $CLAUDE_SETUP"

MCP_DIRS=(
  "$HOME/mcp-servers/mcp-server-xlsx"
)

# =============================================================================
# Build firejail command arguments
# =============================================================================
FIREJAIL_ARGS=(
    # Security restrictions
    --noprofile                # Use noprofile to avoid default restrictions that might block large directories
    --allusers                 # Permits access for /home/linuxbrew as it would be hidden
    --private-tmp              # Private /tmp directory
    --noroot                   # Disable su/sudo inside sandbox
    --caps.drop=all            # Drop all capabilities
    --nonewprivs               # Prevent privilege escalation
    --nogroups                 # Don't inherit supplementary groups

    # Filesystem access - whitelist specific paths only
    --whitelist="$CURRENT_DIR"              # Allow access to current directory
    --read-write="$CURRENT_DIR"             # Make current directory writable
    --whitelist="$BREW_ROOT"                # Allow access to brew root (when mise and uv use it)
    --whitelist="$MISE_BIN"                 # Allow access to mise to manage projects
    --whitelist="$MISE_DATA"                # Allow access to mise-installed languages
    --whitelist="$NODE_BIN"                 # Allow access to node binary
    --whitelist="$NODE_INSTALL_ROOT"        # Allow access to the root of the node installation
    --whitelist="$UV_BIN"                   # Allow access to uv for python-only projects
    --whitelist="$UVX_BIN"                  # Allow access to uvx for executions of tools
    --whitelist="$UV_DATA"                  # Allow access to uv-installed python versions
    --whitelist="$UV_CACHE"                 # Allow access to uv-installed package cache
    --whitelist="$CLAUDE_BIN"               # Allow access to claude script
    --whitelist="$(dirname "$CLAUDE_BIN")"  # Allow access to claude script directory
)

# Add Claude configuration access if files/directories exist
if [ -d "$HOME/.claude" ]; then
    FIREJAIL_ARGS+=(--whitelist="$HOME/.claude")
    FIREJAIL_ARGS+=(--read-write="$HOME/.claude")
fi
if [ -f "$HOME/.claude.json" ]; then
    FIREJAIL_ARGS+=(--whitelist="$HOME/.claude.json")
    FIREJAIL_ARGS+=(--read-write="$HOME/.claude.json")
fi

# Add project-level .claude directory if it exists
if [ -d "./.claude" ]; then
    FIREJAIL_ARGS+=(--whitelist="$CURRENT_DIR/.claude")
    FIREJAIL_ARGS+=(--read-write="$CURRENT_DIR/.claude")
fi

# Loop through local mcp server directories
for dir in "${MCP_DIRS[@]}"; do
    if [ -d "$dir" ]; then
        FIREJAIL_ARGS+=(--whitelist="$dir")
        echo "Whitelisting MCP Directory: $dir"
    else
        echo "Warning: MCP directory not found, skipping: $dir"
    fi
done

# Network access (allow by default, can be restricted with --net=none)
# FIREJAIL_ARGS+=(--net=none)  # Uncomment to disable network access

# =============================================================================
# Run the sandbox
# =============================================================================
echo "Starting claude in firejail sandbox..."
exec firejail "${FIREJAIL_ARGS[@]}" /bin/bash -c "$SHELL_SETUP" -- "$@"
